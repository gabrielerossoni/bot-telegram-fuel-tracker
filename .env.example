# 1. Copia questo file in .env
# 2. Compila i valori qui sotto

# Token del bot da @BotFather
BOT_TOKEN=il_tuo_token_qui

# URL della Web App (ngrok in locale, o URL del server in produzione)
# Deve iniziare con https://
WEBAPP_URL=X

# Porta del server (opzionale, default 8080)
PORT=8080

# --- Default Fallback ---
# Il tuo ID Telegram (da @userinfobot) per i report CLI (opzionale)
CHAT_ID=
LAT=
LON=
RAGGIO=
CARBURANTE=
SELF_SERVICE=true
SOGLIA=
ORARIO=08:00
